{
  "name": "analysis-mysql-connector",
  "config": {
    "connector.class": "io.debezium.connector.mysql.MySqlConnector",
    "tasks.max": "1",

    "database.hostname": "host.docker.internal",
    "database.port": "3306",
    "database.user": "root",
    "database.password": "test1234",
    "database.server.id": "184055",
    "database.serverTimezone": "Asia/Seoul",
    "database.connectionTimeZone": "Asia/Seoul",
    "database.include.list": "peoplecore",

    "topic.prefix": "analysis",
    "table.include.list": "peoplecore.eval_grade,peoplecore.manager_evaluation,peoplecore.season",

    "schema.history.internal.kafka.bootstrap.servers": "kafka:29092",
    "schema.history.internal.kafka.topic": "schema-changes.analysis",
    "include.schema.changes": "false",

    "snapshot.mode": "initial"
  }
}
